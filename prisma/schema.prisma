generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")  // ✅ 使用 Supabase PgBouncer 连接池（:6543）
  directUrl = env("DIRECT_URL")           // ✅ migration 用直连 URL（:5432）
}

// ─────────────────────────────────────────
// 管理员账号（后台登录）
// ─────────────────────────────────────────
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

// ─────────────────────────────────────────
// 用户表
// ─────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatar         String?
  bio            String?  // REQ-12.4: 用户简介
  cover          String?  // REQ-12.4: 用户头图
  specialties    String[] // REQ-12.4: 擅长菜系（多选）
  role           UserRole @default(USER)
  locale         String   @default("en")
  location       String?  // REQ-18.1: 所在地
  gender         UserGender? // REQ-18.1: 性别
  expoPushToken  String?
  passwordHash   String?
  loginAttempts  Int      @default(0)
  lockedUntil    DateTime?
  isBanned       Boolean  @default(false)
  bannedAt       DateTime?
  bannedReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  exp            Int      @default(0)  // REQ-12.9: 经验值（改名自 xp）
  level          Int      @default(1)  // REQ-12.9: 等级 1-10

  recipes       Recipe[]
  comments      Comment[]
  likes         Like[]
  commentLikes  CommentLike[]
  favorites     Favorite[]
  notifications Notification[]
  following     Follow[]      @relation("UserFollowing")
  followers     Follow[]      @relation("UserFollowers")
  reports       Report[]
  badges        UserBadge[]
  browseHistory BrowseHistory[] // REQ-12.7: 浏览历史
  searchHistory SearchHistory[] // REQ-14.6: 搜索历史
  topicFollowers TopicFollower[] // REQ-14.4: 话题关注
  healthProfile UserHealthProfile? // SPRINT-004: 健康档案
  dailyIntakes  DailyIntake[]      // SPRINT-004: 每日摄入
  nutritionReports NutritionReport[] // SPRINT-004: 周报告
  subscription  Subscription?       // Premium 订阅
  aiAnalysis       AiRecipeAnalysis[]  // AI 功能套件：分析记录
  aiGeneratedRecipes AiGeneratedRecipe[] // AI 功能套件：生成记录
  aiUsageQuota     AiUsageQuota?       // AI 功能套件：配额跟踪

  // REQ-18.5: 性能索引
  @@index([email])     // 邮箱查询（登录）
  @@index([name])      // 昵称查询（用于去重和搜索）
  @@index([createdAt]) // 用户列表排序（按注册时间）
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

enum UserGender {
  MALE
  FEMALE
  OTHER
  PRIVATE
}

// ─────────────────────────────────────────
// 菜谱分类
// ─────────────────────────────────────────
model Category {
  id          String   @id @default(cuid())
  nameEn      String
  nameZh      String
  slug        String   @unique
  image       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  recipes     Recipe[]

  @@map("categories")
}

// ─────────────────────────────────────────
// 菜谱主表
// ─────────────────────────────────────────
model Recipe {
  id            String       @id @default(cuid())
  titleEn       String
  titleZh       String
  descriptionEn String?
  descriptionZh String?
  coverImage    String?
  // 需求 15：以下字段改为可选 —— 未填时 App 详情页不渲染对应 icon（见
  // `chefchina-app/app/recipe/[id].tsx` 的 meta bar）。旧种子数据会保留原值，
  // 新增菜谱可以在编辑表单中留空。
  difficulty    Difficulty?
  prepTime      Int?
  cookTimeMin   Int?
  servings      Int?
  calories      Int?
  protein       Float?       // 蛋白质(g)
  fat           Float?       // 脂肪(g)
  carbs         Float?       // 碳水化合物(g)
  fiber         Float?       // 膳食纤维(g)
  sodium        Float?       // 钠(mg)
  sugar         Float?       // 糖(g)
  isPublished   Boolean      @default(false)
  viewCount     Int          @default(0)
  authorId      String
  categoryId    String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  author        User         @relation(fields: [authorId], references: [id])
  category      Category     @relation(fields: [categoryId], references: [id])
  steps         RecipeStep[]
  ingredients   Ingredient[]
  comments      Comment[]
  likes         Like[]
  favorites     Favorite[]
  tags          RecipeTag[]
  topics        RecipeTopic[] // REQ-12.3: 话题关联
  browseHistory BrowseHistory[] // REQ-12.7: 浏览历史
  dailyIntakes  DailyIntake[]   // SPRINT-004: 每日摄入关联
  aiAnalysis       AiRecipeAnalysis[]  // AI 功能套件：分析记录
  aiGeneratedFrom  AiGeneratedRecipe[] // AI 功能套件：被 AI 生成关联

  // REQ-18.5: 性能索引
  @@index([authorId])           // 用户的菜谱列表
  @@index([categoryId])         // 分类筛选
  @@index([createdAt])          // 最新菜谱排序
  @@index([viewCount])          // 热门排行
  @@index([isPublished])        // 已发布/草稿筛选
  @@index([authorId, createdAt]) // 组合索引：用户菜谱按时间排序
  @@map("recipes")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─────────────────────────────────────────
// 菜谱步骤
// ─────────────────────────────────────────
model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  stepNumber  Int
  titleEn     String?
  titleZh     String?
  contentEn   String
  contentZh   String
  image       String?
  durationMin Int?
  createdAt   DateTime @default(now())

  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

// ─────────────────────────────────────────
// 食材
// ─────────────────────────────────────────
model Ingredient {
  id         String   @id @default(cuid())
  recipeId   String
  nameEn     String
  nameZh     String
  amount     String
  unit       String?
  isOptional Boolean  @default(false)

  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

// ─────────────────────────────────────────
// 标签
// ─────────────────────────────────────────
model Tag {
  id      String      @id @default(cuid())
  nameEn  String      @unique
  nameZh  String

  recipes RecipeTag[]

  @@map("tags")
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@map("recipe_tags")
}

// ─────────────────────────────────────────
// 评论
// ─────────────────────────────────────────
model Comment {
  id            String   @id @default(cuid())
  content       String
  rating        Int?     // 1-5 星
  images        String[] // 评论图片数组（存储 base64 或 URL）
  recipeId      String
  userId        String
  parentId      String?  // 楼中楼回复（最多 2 层）
  replyToUserId String?  // 直接回复给谁
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recipe        Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])
  parent        Comment?    @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[]   @relation("CommentReplies")
  likes         CommentLike[]

  // REQ-18.5: 性能索引
  @@index([recipeId, createdAt]) // 菜谱评论按时间排序
  @@index([userId])              // 用户的评论列表
  @@index([parentId])
  @@index([replyToUserId])
  @@map("comments")
}

// ─────────────────────────────────────────
// 菜谱点赞
// ─────────────────────────────────────────
model Like {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id])
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
  @@map("likes")
}

// ─────────────────────────────────────────
// 评论点赞
// ─────────────────────────────────────────
model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

// ─────────────────────────────────────────
// 收藏
// ─────────────────────────────────────────
model Favorite {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id])
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
  @@map("favorites")
}

// ─────────────────────────────────────────
// 消息通知（站内信）
// ─────────────────────────────────────────
model Notification {
  id         String           @id @default(cuid())
  userId     String           // 接收者 recipient
  type       NotificationType
  title      String
  body       String
  payload    Json?            // { recipeId?, commentId?, fromUserId? ... }
  // 结构化字段：用来做数据库层面的 24h 去重 (actorId, userId, type, resourceId)
  actorId    String?          // 触发者（点赞者 / 回复者 / 收藏者 …）
  resourceId String?          // 触发对应的资源 id（recipeId / commentId / …）
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  // BUG-007 修复：删掉与下方 @@unique 完全重复的四元组 index —— unique index
  // 本身就是 B-tree 索引，可以服务等值查询（actorId/userId/type/resourceId），
  // 没必要再建一条普通 index 占写入成本。
  // 24h dedup 由应用层 + DB unique 双保险，但 DB 不能带时间条件，只能保证
  // "同一 actor/recipient/type/resource 不会同时存在两条"；应用侧 `hasRecentNotification`
  // 再配合 24h 时间窗过滤即可。Upsert 失败也会被 createNotification 的 try/catch 吞掉。
  @@unique([actorId, userId, type, resourceId])
  @@map("notifications")
}

enum NotificationType {
  COMMENT_REPLY
  RECIPE_LIKED
  RECIPE_FAVORITED
  SUBMISSION_APPROVED
  SYSTEM
}

// ─────────────────────────────────────────
// 分享日志
// ─────────────────────────────────────────
model ShareLog {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String?
  channel   String?           // wechat / instagram / copy / other
  createdAt DateTime @default(now())

  @@index([recipeId])
  @@map("share_logs")
}

// ─────────────────────────────────────────
// 用户关注
// ─────────────────────────────────────────
model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@unique([followerId, followingId]) // 防止重复关注
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ─────────────────────────────────────────
// 搜索日志（FEAT · /api/recipes/search 写入、/api/search/trending 聚合）
// ─────────────────────────────────────────
// 目前 admin 还有 Redis 版 /api/search-log + /api/search-trending（共用 ZSET），
// 本模型是 SQL 版的持久化通道：
//   - /api/recipes/search 落库：用户 userId（可空，匿名也记）+ normalize 过的 keyword
//   - /api/search/trending 聚合：最近 7 天按 keyword 频次排序 + Redis 5 分钟缓存
// Redis 版不会动（前向兼容）；两套并行直到老接口下线。
model SearchLog {
  id        String   @id @default(cuid())
  userId    String?
  keyword   String
  createdAt DateTime @default(now())

  @@index([keyword, createdAt])
  @@map("search_logs")
}

// ─────────────────────────────────────────────
// 举报（需求 4）
// ─────────────────────────────────────────────
model Report {
  id           String       @id @default(cuid())
  reporterId   String       // 举报者
  targetType   ReportTarget // RECIPE 或 COMMENT
  targetId     String       // 被举报的菜谱/评论 id
  reason       ReportReason
  description  String?      // 补充说明
  status       ReportStatus @default(PENDING)
  adminNote    String?      // 后台处理备注
  resolvedAt   DateTime?
  resolvedBy   String?      // 处理人 userId
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reporter     User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

enum ReportTarget {
  RECIPE
  COMMENT
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  COPYRIGHT
  HARMFUL
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ─────────────────────────────────────────
// 话题标签系统（REQ-12.3）
// ─────────────────────────────────────────
model Topic {
  id          String        @id @default(cuid())
  nameEn      String
  nameZh      String
  descEn      String?
  descZh      String?
  icon        String?       // emoji 或图标
  coverImage  String?       // 话题封面
  isHot       Boolean       @default(false)  // 是否热门话题
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  recipes     RecipeTopic[]
  followers   TopicFollower[] // REQ-15.1: 话题关注者

  @@map("topics")
}

model RecipeTopic {
  recipeId    String
  topicId     String
  createdAt   DateTime      @default(now())

  recipe      Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  topic       Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([recipeId, topicId])
  @@index([topicId])
  @@map("recipe_topics")
}

// ─────────────────────────────────────────
// 浏览历史（REQ-12.7 推荐算法）
// ─────────────────────────────────────────
model BrowseHistory {
  id          String   @id @default(cuid())
  userId      String
  recipeId    String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])  // 同一用户对同一菜谱只记录一次（最新）
  @@index([userId, createdAt])
  @@index([recipeId])
  @@map("browse_history")
}

// ─────────────────────────────────────────
// 经验值规则（REQ-12.9）
// ─────────────────────────────────────────
model ExpRule {
  id          String   @id @default(cuid())
  action      String   @unique  // "post_recipe", "get_like", "get_favorite", "daily_login"
  exp         Int               // 获得的经验值
  dailyLimit  Int?              // 每日上限（null 表示无限制）
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("exp_rules")
}

model LevelConfig {
  level       Int      @id       // 1-10
  expRequired Int               // 达到该等级需要的总经验值
  nameEn      String
  nameZh      String
  benefits    String            // JSON 字符串描述权益
  createdAt   DateTime @default(now())

  @@map("level_configs")
}

// ─────────────────────────────────────────
// 成就徽章
// ─────────────────────────────────────────
model Badge {
  id        String      @id @default(cuid())
  key       String      @unique          // 如 "first_recipe", "10_likes"
  nameEn    String
  nameZh    String
  descEn    String
  descZh    String
  icon      String                        // emoji 或图标名
  category  String                        // "cooking", "social", "streak", "milestone"
  threshold Int                           // 达成条件阈值
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  users     UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ─────────────────────────────────────────
// Batch 14: 搜索历史 & 热门搜索词 & 话题关注
// ─────────────────────────────────────────

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  query       String
  resultCount Int      @default(0) @map("result_count")
  clicked     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("search_history")
}

model SearchTrending {
  id           String   @id @default(cuid())
  keyword      String
  searchCount  Int      @default(0) @map("search_count")
  clickRate    Float    @default(0) @map("click_rate")
  score        Float    @default(0)
  trendingType String?  @map("trending_type") // 'hot' | 'rising' | 'new'
  hourWindow   DateTime @map("hour_window")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([hourWindow, score(sort: Desc)])
  @@map("search_trending")
}

model TopicFollower {
  topicId   String
  userId    String
  createdAt DateTime @default(now())

  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([topicId, userId])
  @@index([topicId])
  @@index([userId])
  @@map("topic_followers")
}

// ─────────────────────────────────────────
// SPRINT-004: 个性化营养档案
// ─────────────────────────────────────────

// 1. 用户健康档案
model UserHealthProfile {
  userId          String   @id
  goal            String   // weight_loss/muscle_gain/maintain
  dailyCalories   Int      // 1200-3000
  proteinPercent  Int      // 20-40
  fatPercent      Int      // 20-35
  carbsPercent    Int      // 30-60
  sodiumLimit     Int?     // mg
  sugarLimit      Int?     // g
  fiberMin        Int?     // g
  restrictions    String[] // ["low_sodium", "low_sugar"]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_health_profiles")
}

// 2. 每日摄入记录
model DailyIntake {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  recipeId  String
  mealType  String   // breakfast/lunch/dinner/snack
  servings  Float    @default(1.0)
  calories  Float
  protein   Float
  fat       Float
  carbs     Float
  fiber     Float?
  sodium    Float?
  sugar     Float?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("daily_intakes")
}

// 3. 周营养报告
model NutritionReport {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime @db.Date
  weekEnd      DateTime @db.Date
  reportData   Json     // 统计数据
  aiAdvice     String?  // AI 建议（暂时可为空）
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
  @@map("nutrition_reports")
}

// ─────────────────────────────────────────
// Premium 订阅系统
// ─────────────────────────────────────────

// 订阅表
model Subscription {
  id                   String           @id @default(cuid())
  userId               String           @unique
  planType             SubscriptionPlan @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  CANCELLED
  EXPIRED
}

// 支付交易记录
model PaymentTransaction {
  id                String   @id @default(cuid())
  userId            String
  subscriptionId    String?
  stripePaymentId   String?  @unique
  amount            Int      // 金额（美分）
  currency          String   @default("usd")
  status            PaymentStatus @default(PENDING)
  paymentMethod     String?  // card, apple_pay, etc.
  receiptUrl        String?
  errorMessage      String?
  metadata          Json?    // 额外信息
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([stripePaymentId])
  @@index([createdAt])
  @@map("payment_transactions")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

// ─────────────────────────────────────────
// AI 功能套件（SPRINT-005）
// ─────────────────────────────────────────

// 1. AI 菜谱分析结果（缓存）
model AiRecipeAnalysis {
  id              String   @id @default(cuid())
  userId          String
  recipeId        String
  matchScore      Int      // 0-100
  summary         String   @db.Text
  pros            String[] // 优点列表
  cons            String[] // 缺点列表
  modifications   String[] // 改良建议
  alternatives    Json     // [{ recipeId, title, reason }]
  createdAt       DateTime @default(now())
  expiresAt       DateTime // 7天后过期

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId], name: "user_recipe_unique")
  @@index([userId, createdAt])
  @@index([expiresAt]) // 用于定期清理
  @@map("ai_recipe_analysis")
}

// 2. AI 生成菜谱历史
model AiGeneratedRecipe {
  id              String   @id @default(cuid())
  userId          String
  recipeId        String?  // 发布后关联
  inputIngredients String[] // 用户输入的食材
  style           String?  // 川菜/粤菜/日式/西式
  difficulty      String?  // EASY/MEDIUM/HARD
  generatedData   Json     // AI 返回的完整 JSON
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  expiresAt       DateTime // 草稿 7 天后过期

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([isPublished])
  @@index([expiresAt]) // 用于定期清理过期草稿
  @@map("ai_generated_recipes")
}

// 3. AI 使用配额跟踪
model AiUsageQuota {
  id                    String   @id @default(cuid())
  userId                String   @unique
  
  // 分析功能（每日重置）
  analysisUsedToday     Int      @default(0)
  analysisResetAt       DateTime // 下次重置时间（明天 00:00）
  
  // 生成功能（每月重置）
  generatorUsedThisMonth Int     @default(0)
  generatorResetAt      DateTime // 下次重置时间（下月 1 号）
  
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_usage_quota")
}
